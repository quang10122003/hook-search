    "authentication": {
      "password": {
        "description": "User enters username and password",
        "advantages": "Simple and easy to implement",
        "disadvantages": "Weak passwords reduce security"
      },
      "jwt": {
        "description": "Token-based authentication",
        "advantages": "Stateless and scalable",
        "disadvantages": "Hard to revoke immediately"
      },
      "session": {
        "description": "Server stores user session",
        "advantages": "Easy to manage and revoke",
        "disadvantages": "Harder to scale under high load"
      },
      "oauth": {
        "description": "Login via providers like Google/Facebook",
        "advantages": "No additional password to remember",
        "disadvantages": "Depends on third-party services"
      },
      "twoFa": {
        "description": "Password plus one-time passcode",
        "advantages": "Higher security",
        "disadvantages": "Adds extra steps for users"
      },
      "biometric": {
        "description": "Fingerprint or Face ID",
        "advantages": "Convenient and secure",
        "disadvantages": "Requires compatible hardware"
      }
    },
    "authorization": {
      "rbac": {
        "description": "Role-Based Access Control",
        "advantages": "Popular and easy to manage",
        "disadvantages": "Less flexible in large systems"
      },
      "abac": {
        "description": "Attribute-Based Access Control",
        "advantages": "Highly flexible",
        "disadvantages": "Complex to implement and maintain"
      },
      "acl": {
        "description": "Access Control List per resource",
        "advantages": "Fine-grained access control",
        "disadvantages": "Hard to manage at scale"
      },
      "pbac": {
        "description": "Policy-Based Access Control",
        "advantages": "Centralized policy management",
        "disadvantages": "Requires a policy engine"
      },
      "oauthScope": {
        "description": "Authorization based on API scopes",
        "advantages": "Well-suited for microservices",
        "disadvantages": "Can be difficult with many scopes"
      }
    },
